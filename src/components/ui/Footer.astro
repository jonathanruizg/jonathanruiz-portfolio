</footer>

<style>
  .footer-root {
    padding-top: 2rem;
    padding-bottom: 5rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .footer-copy {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    color: var(--text-3);
    margin: 0;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }
  .footer-links a {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    color: var(--text-3);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-links a:hover { color: var(--text); }
  .footer-sep {
    font-size: 0.72rem;
    color: var(--text-3);
  }

  @media (max-width: 480px) {
    .footer-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0.75rem;
    }
  }
</style>
