<section id="hero" class="min-h-screen flex items-center section-padding pt-20 md:pt-0" style="position: relative;">
  <!-- WebGL dot grid -->
  <canvas id="webgl-canvas" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0;"></canvas>

  <div class="section-container w-full" style="position: relative; z-index: 2;">
    <!-- Headshot: above h1, left aligned -->
    <img
      src="/JR-Headshot-Circular.png"
      alt="Jonathan Ruiz, Sr. Product Design Manager"
      class="hero-photo animate-slide-up"
      style="opacity: 0; animation-fill-mode: forwards;"
    />

    <!-- Headline -->
    <h1 class="hero-h1 text-balance animate-slide-up" style="opacity: 0; animation-fill-mode: forwards;">
      Designing with <span style="color: var(--accent);">purpose.</span><br />
      Leading with empathy.
    </h1>

    <!-- Bio -->
    <p
      class="body-text max-w-prose text-base mb-10 animate-slide-up"
      style="animation-delay: 0.1s; opacity: 0; animation-fill-mode: forwards;"
    >
      I'm Jonathan, Husband, Father of two, Sr. Product Design Manager at Docusign and co-leader of Friends of Figma Miami. I help teams build thoughtful, accessible,
      and deeply human experiences.
    </p>

    <!-- CTAs -->
    <div
      class="flex flex-wrap gap-3 mb-12 animate-slide-up"
      style="animation-delay: 0.2s; opacity: 0; animation-fill-mode: forwards;"
    >
      <a href="#work" class="btn-primary">
        View my work
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a href="mailto:jonathanruizg@me.com" class="btn-ghost">Say hello</a>
    </div>

    <!-- Scripture card -->
    <div
      class="max-w-prose animate-slide-up"
      style="animation-delay: 0.3s; opacity: 0; animation-fill-mode: forwards;"
    >
      <div
        class="px-5 py-4 rounded-lg border-l-2"
        style="background-color: var(--bg-2); border-left-color: var(--accent); border-top: 1px solid var(--border); border-right: 1px solid var(--border); border-bottom: 1px solid var(--border);"
      >
        <p class="text-sm leading-relaxed italic mb-1.5" style="color: var(--text-2);">
          "Whatever you do, work at it with all your heart, as working for the Lord."
        </p>
        <p class="text-xs font-medium" style="font-family: 'DM Mono', monospace; color: var(--accent);">
          — Colossians 3:23
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-photo {
    display: block;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--border);
    margin-bottom: 1.75rem;
  }

  .hero-h1 {
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--text);
    margin-bottom: 1rem;
  }
</style>

<script>
const canvas = document.getElementById('webgl-canvas') as HTMLCanvasElement;
const gl = canvas?.getContext('webgl');

if (gl) {
  const vsSource = `
    attribute vec2 a_pos;
    attribute float a_baseX;
    attribute float a_baseY;
    uniform vec2 u_mouse;
    uniform vec2 u_resolution;
    uniform float u_time;
    varying float v_dist;
    varying float v_alpha;
    void main() {
      vec2 base = vec2(a_baseX, a_baseY);
      vec2 mouseNorm = u_mouse / u_resolution;
      mouseNorm.y = 1.0 - mouseNorm.y;
      float dist = distance(base, mouseNorm);
      float influence = smoothstep(0.25, 0.0, dist);
      float angle = atan(base.y - mouseNorm.y, base.x - mouseNorm.x);
      float ripple = sin(dist * 18.0 - u_time * 3.0) * 0.012 * influence;
      float push = influence * 0.04;
      vec2 displaced = base;
      displaced.x += cos(angle) * (push + ripple);
      displaced.y += sin(angle) * (push + ripple);
      vec2 clip = (displaced * 2.0) - 1.0;
      clip.y *= -1.0;
      gl_Position = vec4(clip, 0.0, 1.0);
      gl_PointSize = mix(1.5, 3.5, influence) + sin(u_time + a_baseX * 10.0) * 0.3;
      v_dist = dist;
      v_alpha = influence;
    }
  `;
  const fsSource = `
    precision mediump float;
    varying float v_alpha;
    uniform float u_isDark;
    void main() {
      vec2 coord = gl_PointCoord - 0.5;
      float r = length(coord);
      if (r > 0.5) discard;
      float baseAlpha = mix(0.3, 0.15, u_isDark);
      float alpha = mix(baseAlpha, 0.9, v_alpha);
      alpha *= (1.0 - r * 1.5);
      vec3 baseDark = vec3(0.4, 0.4, 0.38);
      vec3 baseLight = vec3(0.45, 0.43, 0.41);
      vec3 baseColor = mix(baseLight, baseDark, u_isDark);
      vec3 accent = vec3(1.0, 0.373, 0.251);
      vec3 color = mix(baseColor, accent, v_alpha * 0.9);
      gl_FragColor = vec4(color, alpha);
    }
  `;
  function createShader(gl: WebGLRenderingContext, type: number, src: string) {
    const s = gl.createShader(type)!;
    gl.shaderSource(s, src);
    gl.compileShader(s);
    return s;
  }
  const vs = createShader(gl, gl.VERTEX_SHADER, vsSource);
  const fs = createShader(gl, gl.FRAGMENT_SHADER, fsSource);
  const program = gl.createProgram()!;
  gl.attachShader(program, vs);
  gl.attachShader(program, fs);
  gl.linkProgram(program);
  gl.useProgram(program);
  let cols: number, rows: number, positions: Float32Array, baseXs: Float32Array, baseYs: Float32Array;
  function buildGrid() {
    cols = Math.floor(canvas.width / 28);
    rows = Math.floor(canvas.height / 28);
    const count = cols * rows;
    positions = new Float32Array(count * 2);
    baseXs = new Float32Array(count);
    baseYs = new Float32Array(count);
    for (let row = 0; row < rows; row++) {
      for (let col = 0; col < cols; col++) {
        const i = row * cols + col;
        const nx = (col + 0.5) / cols;
        const ny = (row + 0.5) / rows;
        positions[i * 2] = nx;
        positions[i * 2 + 1] = ny;
        baseXs[i] = nx;
        baseYs[i] = ny;
      }
    }
  }
  const posBuffer = gl.createBuffer()!;
  const baseXBuffer = gl.createBuffer()!;
  const baseYBuffer = gl.createBuffer()!;
  function uploadBuffers() {
    gl.bindBuffer(gl.ARRAY_BUFFER, posBuffer);
    gl.bufferData(gl.ARRAY_BUFFER, positions, gl.DYNAMIC_DRAW);
    const posLoc = gl.getAttribLocation(program, 'a_pos');
    gl.enableVertexAttribArray(posLoc);
    gl.vertexAttribPointer(posLoc, 2, gl.FLOAT, false, 0, 0);
    gl.bindBuffer(gl.ARRAY_BUFFER, baseXBuffer);
    gl.bufferData(gl.ARRAY_BUFFER, baseXs, gl.STATIC_DRAW);
    const bxLoc = gl.getAttribLocation(program, 'a_baseX');
    gl.enableVertexAttribArray(bxLoc);
    gl.vertexAttribPointer(bxLoc, 1, gl.FLOAT, false, 0, 0);
    gl.bindBuffer(gl.ARRAY_BUFFER, baseYBuffer);
    gl.bufferData(gl.ARRAY_BUFFER, baseYs, gl.STATIC_DRAW);
    const byLoc = gl.getAttribLocation(program, 'a_baseY');
    gl.enableVertexAttribArray(byLoc);
    gl.vertexAttribPointer(byLoc, 1, gl.FLOAT, false, 0, 0);
  }
  const mouseLoc = gl.getUniformLocation(program, 'u_mouse');
  const resLoc = gl.getUniformLocation(program, 'u_resolution');
  const timeLoc = gl.getUniformLocation(program, 'u_time');
  const isDarkLoc = gl.getUniformLocation(program, 'u_isDark');
  let mouse = { x: -9999, y: -9999 };
  let smoothMouse = { x: -9999, y: -9999 };
  canvas.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    mouse.x = e.clientX - rect.left;
    mouse.y = e.clientY - rect.top;
  });
  canvas.addEventListener('mouseleave', () => {
    mouse.x = -9999;
    mouse.y = -9999;
  });
  function resize() {
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width;
    canvas.height = rect.height;
    gl.viewport(0, 0, canvas.width, canvas.height);
    buildGrid();
    uploadBuffers();
  }
  setTimeout(resize, 100);
  window.addEventListener('resize', resize);
  gl.enable(gl.BLEND);
  gl.blendFunc(gl.SRC_ALPHA, gl.ONE_MINUS_SRC_ALPHA);
  const startTime = Date.now();
  function render() {
    const t = (Date.now() - startTime) / 1000;
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark' ? 1.0 : 0.0;
    smoothMouse.x += (mouse.x - smoothMouse.x) * 0.08;
    smoothMouse.y += (mouse.y - smoothMouse.y) * 0.08;
    gl.clearColor(0, 0, 0, 0);
    gl.clear(gl.COLOR_BUFFER_BIT);
    gl.uniform2f(mouseLoc, smoothMouse.x, smoothMouse.y);
    gl.uniform2f(resLoc, canvas.width, canvas.height);
    gl.uniform1f(timeLoc, t);
    gl.uniform1f(isDarkLoc, isDark);
    gl.bindBuffer(gl.ARRAY_BUFFER, posBuffer);
    gl.bufferData(gl.ARRAY_BUFFER, positions, gl.DYNAMIC_DRAW);
    gl.drawArrays(gl.POINTS, 0, cols * rows);
    requestAnimationFrame(render);
  }
  render();
}
</script>
