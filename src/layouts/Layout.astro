---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Jonathan Ruiz — Sr. Design Manager',
  description = 'Portfolio of Jonathan Ruiz — Sr. Product Design Manager at Docusign, educator, and community builder based in Miami.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Prevent dark mode flash -->
    <script is:inline>
      const s = localStorage.getItem('theme');
      const p = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (s === 'dark' || (!s && p)) document.documentElement.classList.add('dark');
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
