---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/ui/Sidebar.astro';
import Footer from '../components/ui/Footer.astro';

const tags = [
  'Leadership', 'AI × Design', 'Strategy', 'Accessibility','Interaction Design','Design Systems',
  'Mentorship',  'Vibe Coding', 'Community Building', 
];

const books = [
  {
    title: 'UX for AI: A Framework for Designing AI-Driven Products',
    author: 'Yury Vetrov',
    isbn: '9781394345922',
    preorder: null,
  },
  {
    title: 'Leonardo da Vinci',
    author: 'Walter Isaacson',
    isbn: '9781501139154',
    preorder: null,
  },
  {
    title: 'Principles of Building AI Agents',
    author: 'Sam Bhagwat',
    isbn: '9798312004281',
    preorder: null,
  },
  {
    title: 'Sentient Design',
    author: 'Josh Clark & Veronika Kindred',
    isbn: null,
    preorder: 'Pre-ordered · June 2026',
  },
];

const musicArtists = [
  { id: 'snarky-puppy',   term: 'Snarky Puppy' },
  { id: 'jacob-collier',  term: 'Jacob Collier' },
  { id: 'raveena',        term: 'Raveena' },
  { id: 'planetshakers',  term: 'Planetshakers' },
  { id: 'mutemath',       term: 'Mutemath' },
  { id: 'anderson-paak',  term: 'Anderson Paak' },
  { id: 'tom-misch',      term: 'Tom Misch' },
  { id: 'vulfpeck',       term: 'Vulfpeck' },
  { id: 'fkj',            term: 'FKJ' },
  { id: 'jazz-vibes',     term: 'Jazz Vibes' },
];

const podcasts = [
  'The Ramsey Show',
  'Dwarkesh Podcast',
  'Diary of a CEO with Steven Bartlett',
  'EntreLeadership',
  'Stuff You Should Know',
  'Design System Office Hours',
  'Dive Club',
  'The Economics of Everyday Things',
  'Lex Fridman Podcast',
  'The Joe Rogan Experience',
];
---

<Layout
  title="About — Jonathan Ruiz"
  description="Learn about Jonathan Ruiz — Sr. Product Design Manager at Docusign, educator at BrainStation, and community builder in Miami."
>
  <Sidebar currentPath={Astro.url.pathname} />

  <div class="content-area pt-14 md:pt-0">
    <main>

      <!-- ── Section A: Bio ── -->
      <section class="section-padding">
        <div class="section-container">

          <a href="/" class="back-home">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            Back home
          </a>

          <div class="grid md:grid-cols-[1fr_280px] gap-12 md:gap-16 items-start">
            <div>
              <p class="label mb-3">About</p>
              <h1 class="section-title mb-8" style="font-size: clamp(1.75rem, 4vw, 2.75rem); line-height: 1.1; letter-spacing: -0.02em;">
                Design Manager.<br />Educator.<br />Community builder.
              </h1>

              <div class="about-bio">
                <p>
                 I'm a designer who leads, a leader who still designs, and someone who believes the best products come from the best teams. After a decade spanning Shazam, Glint, and Docusign, I now run the team behind Ink — Docusign's design system. I teach, mentor, and help build the design community in Miami because I genuinely love this craft and the people in it.
                </p>
                <p>
                Outside of work I'm a husband, a dad of two, and a bass player. Faith keeps me grounded, family keeps me honest, and a good workout or a trail run clears my head. Always open to connecting — whether to talk design systems, leadership, vibe coding, or just to say hey.
                </p>
              </div>

              <!-- Tags -->
              <div class="flex flex-wrap gap-2 mt-8 mb-10">
                {tags.map((tag) => (
                  <span
                    class="px-2.5 py-1 text-xs rounded-md"
                    style="background-color: var(--bg-2); color: var(--text-2); border: 1px solid var(--border);"
                  >
                    {tag}
                  </span>
                ))}
              </div>

              <!-- Leadership teaser card -->
              <div
                class="px-5 py-4 rounded-lg border-l-2 max-w-lg"
                style="background-color: var(--bg-2); border-left-color: var(--accent); border-top: 1px solid var(--border); border-right: 1px solid var(--border); border-bottom: 1px solid var(--border);"
              >
                <p class="text-sm leading-relaxed mb-3" style="color: var(--text-2);">
                  "I lead with servant leadership, humble confidence, and a belief that
                  the whole is always greater than the sum of its parts."
                </p>
                <a href="/leadership" class="about-more-link">
                  Read my leadership philosophy
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </div>

            <!-- Right: headshot + role card -->
            <div>
              <div class="profile-card">
                <img
                  src="/JR-Headshot-Circular.png"
                  alt="Jonathan Ruiz"
                  class="profile-headshot"
                />
                <div class="profile-body">
                  <p class="profile-label">Current Role</p>
                  <p class="profile-role">Sr. Product Design Manager</p>
                  <p class="profile-company">Docusign · Miami, FL</p>
                  <div class="profile-divider"></div>
                  <a href="https://linkedin.com/in/jonaruiz" target="_blank" rel="noopener noreferrer" class="profile-link">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10M7 17 17 7"/></svg>
                    LinkedIn
                  </a>
                  <a href="mailto:jonathanruizg@me.com" class="profile-link">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10M7 17 17 7"/></svg>
                    Email
                  </a>
                  <a href="/resume" target="_blank" class="profile-link" style="border-bottom: none;">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10M7 17 17 7"/></svg>
                    Resume
                  </a>
                </div>
              </div>
            </div>
          </div>

        </div>
      </section>

      <!-- ── Section B: Currently Reading ── -->
      <section class="section-padding section-divider">
        <div class="section-container">
          <p class="label mb-8">Currently Reading</p>

          <div class="books-grid">
            {books.map((book) => {
              const uid = book.isbn ?? book.title.toLowerCase().replace(/\s+/g, '-');
              return (
                <div class="book-card">
                  <div class="book-cover-wrap">
                    {book.isbn && (
                      <img
                        id={`book-${uid}`}
                        class="book-cover"
                        src=""
                        alt={book.title}
                        data-isbn={book.isbn}
                        style="display: none;"
                      />
                    )}
                    <div class="book-fallback" id={`fallback-${uid}`}>
                      {book.title.split(' ').slice(0, 2).map(w => w[0]).join('')}
                    </div>
                  </div>
                  <p class="book-title">{book.title}</p>
                  <p class="book-author">{book.author}</p>
                  {book.preorder && (
                    <span class="book-badge">{book.preorder}</span>
                  )}
                </div>
              );
            })}
          </div>
        </div>
      </section>

      <!-- ── Section C: Music ── -->
      <section class="section-padding section-divider">
        <div class="section-container">
          <p class="label mb-8">Currently Listening</p>

          <div class="music-grid" id="music-grid">
            {musicArtists.map((artist) => (
              <div class="music-item">
                <div class="music-art-wrap">
                  <img
                    id={`music-${artist.id}`}
                    class="music-art"
                    src=""
                    alt={artist.term}
                    data-artist={artist.term}
                  />
                  <div class="music-fallback" id={`fallback-${artist.id}`}>
                    {artist.term.split(' ').map(w => w[0]).join('').slice(0, 2)}
                  </div>
                </div>
                <p class="music-name">{artist.term}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ── Section D: Podcasts ── -->
      <section class="section-padding section-divider">
        <div class="section-container">
          <p class="label mb-8">Podcasts</p>

          <div class="podcasts-grid">
            {podcasts.map((pod) => (
              <div class="podcast-item">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-3); flex-shrink: 0; margin-top: 2px;" aria-hidden="true">
                  <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/>
                  <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                  <line x1="12" x2="12" y1="19" y2="22"/>
                </svg>
                <span>{pod}</span>
              </div>
            ))}
          </div>
        </div>
      </section>

    </main>
    <Footer />
  </div>
</Layout>

<style>
  .about-bio {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 60ch;
  }
  .about-bio p {
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--text-2);
  }

  .about-more-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    transition: gap 0.15s;
  }
  .about-more-link:hover { gap: 0.6rem; }

  /* ── Profile card ── */
  .profile-card {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    width: 100%;
  }
  .profile-headshot {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    object-position: top;
    border-radius: 12px 12px 0 0;
    display: block;
  }
  .profile-body {
    padding: 1.1rem 1.25rem 1.25rem;
  }
  .profile-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 0.4rem;
  }
  .profile-role {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.2rem;
  }
  .profile-company {
    font-size: 0.78rem;
    color: var(--text-3);
    margin-bottom: 0;
  }
  .profile-divider {
    height: 1px;
    background: var(--border);
    margin: 1rem 0 0.25rem;
  }
  .profile-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: var(--text-2);
    text-decoration: none;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
    transition: color 0.15s;
  }
  .profile-link:hover { color: var(--accent); }

  /* ── Books ── */
  .books-grid {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .book-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 120px;
  }
  .book-cover-wrap {
    position: relative;
    width: 120px;
    height: 180px;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border);
    background-color: var(--bg-3);
  }
  .book-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .book-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'DM Mono', monospace;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-3);
    background-color: var(--bg-3);
  }
  .book-title {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.4;
  }
  .book-author {
    font-size: 0.68rem;
    color: var(--text-3);
  }
  .book-badge {
    display: inline-block;
    font-size: 0.65rem;
    font-family: 'DM Mono', monospace;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    background-color: var(--accent-light);
    color: var(--accent);
  }

  /* ── Music ── */
  .music-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 768px) {
    .music-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 480px) {
    .music-grid { grid-template-columns: repeat(2, 1fr); }
  }
  .music-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .music-art-wrap {
    position: relative;
    aspect-ratio: 1;
    border-radius: 8px;
    overflow: hidden;
    background-color: var(--bg-3);
  }
  .music-art {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8px;
    transition: transform 0.2s, box-shadow 0.2s;
    display: block;
  }
  .music-art:hover {
    transform: scale(1.03);
    box-shadow: 0 8px 24px rgba(0,0,0,0.18);
  }
  .music-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'DM Mono', monospace;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-3);
    background-color: var(--bg-3);
  }
  .music-name {
    font-size: 0.72rem;
    color: var(--text-2);
    line-height: 1.3;
  }

  /* ── Podcasts ── */
  .podcasts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem 2rem;
  }
  @media (max-width: 600px) {
    .podcasts-grid { grid-template-columns: 1fr; }
  }
  .podcast-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: var(--text-2);
    line-height: 1.4;
  }

  @keyframes pulseDot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(0.85); }
  }
</style>

<script>
  // Fetch Google Books covers client-side
  const bookImgs = document.querySelectorAll<HTMLImageElement>('[data-isbn]');
  bookImgs.forEach(async (img) => {
    const isbn = img.getAttribute('data-isbn');
    if (!isbn) return;
    const fallback = document.getElementById(img.id.replace('book-', 'fallback-'));
    try {
      const res = await fetch(`https://www.googleapis.com/books/v1/volumes?q=isbn:${isbn}`);
      const data = await res.json();
      const links = data?.items?.[0]?.volumeInfo?.imageLinks;
      let url = links?.thumbnail || links?.smallThumbnail;
      if (url) {
        url = url.replace('zoom=1', 'zoom=2').replace('http://', 'https://');
        img.src = url;
        img.style.display = 'block';
        img.onload = () => { if (fallback) (fallback as HTMLElement).style.display = 'none'; };
        img.onerror = () => { img.style.display = 'none'; };
      }
    } catch { /* fallback stays visible */ }
  });

  // Fetch iTunes album art client-side
  const artists = document.querySelectorAll<HTMLImageElement>('[data-artist]');

  artists.forEach(async (img) => {
    const term = img.getAttribute('data-artist');
    const id = img.id;
    const fallbackId = 'fallback-' + id.replace('music-', '');
    const fallback = document.getElementById(fallbackId);

    if (!term) return;

    try {
      const res = await fetch(
        `https://itunes.apple.com/search?term=${encodeURIComponent(term)}&entity=album&limit=1`
      );
      const data = await res.json();
      const artwork = data?.results?.[0]?.artworkUrl100;

      if (artwork) {
        const hires = artwork.replace('100x100', '400x400');
        img.src = hires;
        img.onload = () => {
          if (fallback) fallback.style.display = 'none';
        };
        img.onerror = () => {
          img.style.display = 'none';
        };
      } else {
        img.style.display = 'none';
      }
    } catch {
      img.style.display = 'none';
    }
  });
</script>
