---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/ui/Sidebar.astro';
import Footer from '../components/ui/Footer.astro';

const tags = [
  'Leadership', 'AI × Design', 'Strategy', 'Accessibility','Interaction Design','Design Systems',
  'Mentorship',  'Vibe Coding', 'Community Building', 
];

const books = [
  {
    title: 'UX for AI: A Framework for Designing AI-Driven Products',
    author: 'Greg Nudelman',
    isbn: '9781394345922',
    preorder: null,
  },
  {
    title: 'Leonardo da Vinci',
    author: 'Walter Isaacson',
    isbn: '9781501139154',
    preorder: null,
  },
  {
    title: 'Principles of Building AI Agents',
    author: 'Sam Bhagwat',
    isbn: '9798312004281',
    preorder: null,
  },
  {
    title: 'Sentient Design',
    author: 'Josh Clark & Veronika Kindred',
    isbn: null,
    preorder: 'Pre-ordered · June 2026',
  },
];

const musicArtists = [
  { id: 'snarky-puppy',   term: 'Snarky Puppy' },
  { id: 'jacob-collier',  term: 'Jacob Collier' },
  { id: 'raveena',        term: 'Raveena' },
  { id: 'planetshakers',  term: 'Planetshakers' },
  { id: 'mutemath',       term: 'Mutemath' },
  { id: 'anderson-paak',  term: 'Anderson Paak' },
  { id: 'tom-misch',      term: 'Tom Misch' },
  { id: 'vulfpeck',       term: 'Vulfpeck' },
  { id: 'fkj',            term: 'FKJ' },
  { id: 'jazz-vibes',     term: 'Jazz Vibes' },
];

const podcasts = [
  'The Ramsey Show',
  'Dwarkesh Podcast',
  'Diary of a CEO with Steven Bartlett',
  'EntreLeadership',
  'Stuff You Should Know',
  'Design System Office Hours',
  'Dive Club',
  'The Economics of Everyday Things',
  'Lex Fridman Podcast',
  'The Joe Rogan Experience',
];
---

<Layout
  title="About — Jonathan Ruiz"
  description="Learn about Jonathan Ruiz — Sr. Product Design Manager at Docusign, educator at BrainStation, and community builder in Miami."
>
  <Sidebar currentPath={Astro.url.pathname} />

  <div class="content-area pt-14 md:pt-0">
    <main>

      <!-- ── Section A: Bio ── -->
      <section class="section-padding">
        <div class="section-container">

          <a href="/" class="back-home">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            Back home
          </a>

          <div class="grid md:grid-cols-[1fr_280px] gap-12 md:gap-16 items-start">
            <div>
              <p class="label mb-3">About</p>
              <h1 class="section-title mb-8" style="font-size: clamp(1.75rem, 4vw, 2.75rem); line-height: 1.1; letter-spacing: -0.02em;">
                Design Manager.<br />Educator.<br />Community builder.
              </h1>

              <div class="about-bio">
                <p>
                  With roots in Miami and a career spanning Shazam, Glint, and Docusign,
                  I've spent over a decade shaping digital products used by millions of people.
                </p>
                <p>
                  I joined Docusign in 2019 as a Sr. Product Designer on the Design Systems
                  team — close enough to understand not just what the system was, but what it
                  needed to become. When an opportunity to lead emerged on the Mobile team,
                  I took it. Two years later I came back to Design Systems as Sr. Product
                  Design Manager, this time to lead the team I used to be part of.
                </p>
                <p>
                  Today I manage a team of 3 designers running Ink — Docusign's full design
                  and development system with a contribution model. My approach is rooted in
                  my faith: lead like a servant, design like it matters, and always make room
                  for the people around you to grow.
                </p>
                <p>
                  I also teach at BrainStation, co-lead Friends of Figma Miami, and actively
                  mentor designers navigating the IC-to-manager path.
                </p>
              </div>

              <!-- Tags -->
              <div class="flex flex-wrap gap-2 mt-8 mb-10">
                {tags.map((tag) => (
                  <span
                    class="px-2.5 py-1 text-xs rounded-md"
                    style="background-color: var(--bg-2); color: var(--text-2); border: 1px solid var(--border);"
                  >
                    {tag}
                  </span>
                ))}
              </div>

              <!-- Leadership teaser card -->
              <div
                class="px-5 py-4 rounded-lg border-l-2 max-w-lg"
                style="background-color: var(--bg-2); border-left-color: var(--accent); border-top: 1px solid var(--border); border-right: 1px solid var(--border); border-bottom: 1px solid var(--border);"
              >
                <p class="text-sm leading-relaxed mb-3" style="color: var(--text-2);">
                  "I lead with servant leadership, humble confidence, and a belief that
                  the whole is always greater than the sum of its parts."
                </p>
                <a href="/leadership" class="about-more-link">
                  Read my leadership philosophy
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </div>

            <!-- Right: headshot + role card -->
            <div class="hidden md:block">
              <div class="card overflow-hidden p-0">
                <div style="aspect-ratio: 1 / 1; overflow: hidden;">
                  <img
                    src="/JR-Headshot-Circular.png"
                    alt="Jonathan Ruiz"
                    class="headshot-img"
                    style="width: 100%; height: 100%; object-fit: cover; filter: grayscale(20%); transition: filter 0.3s ease;"
                  />
                </div>
                <div class="px-5 py-4" style="border-bottom: 1px solid var(--border);">
                  <div class="flex items-center gap-2 mb-1.5">
                    <span class="w-1.5 h-1.5 rounded-full" style="background-color: var(--color-online); animation: pulseDot 2s ease-in-out infinite;"></span>
                    <span class="label text-[10px]">Current role</span>
                  </div>
                  <p class="text-sm font-semibold mb-0.5" style="color: var(--text);">Sr. Product Design Manager</p>
                  <p class="text-sm" style="color: var(--text-3);">Docusign · Miami, FL</p>
                </div>
                <div class="px-5 py-4 flex gap-2 flex-wrap">
                  <a href="https://linkedin.com/in/jonaruiz" target="_blank" rel="noopener" class="btn-ghost text-xs py-1.5 px-3">LinkedIn</a>
                  <a href="mailto:jonathanruizg@me.com" class="btn-ghost text-xs py-1.5 px-3">Email</a>
                </div>
              </div>
            </div>
          </div>

        </div>
      </section>

      <!-- ── Section B: Currently Reading ── -->
      <section class="section-padding section-divider">
        <div class="section-container">
          <p class="label mb-8">Currently Reading</p>

          <div class="books-grid">
            {books.map((book) => (
              <div class="book-card">
                <div class="book-cover-wrap">
                  {book.isbn ? (
                    <img
                      src={`https://covers.openlibrary.org/b/isbn/${book.isbn}-L.jpg`}
                      alt={book.title}
                      class="book-cover"
                      onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
                    />
                  ) : null}
                  <div
                    class="book-fallback"
                    style={book.isbn ? 'display:none' : 'display:flex'}
                  >
                    {book.title.split(' ').slice(0, 2).map(w => w[0]).join('')}
                  </div>
                </div>
                <p class="book-title">{book.title}</p>
                <p class="book-author">{book.author}</p>
                {book.preorder && (
                  <span class="book-badge">{book.preorder}</span>
                )}
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ── Section C: Music ── -->
      <section class="section-padding section-divider">
        <div class="section-container">
          <p class="label mb-8">Currently Listening</p>

          <div class="music-grid" id="music-grid">
            {musicArtists.map((artist) => (
              <div class="music-item">
                <div class="music-art-wrap">
                  <img
                    id={`music-${artist.id}`}
                    class="music-art"
                    src=""
                    alt={artist.term}
                    data-artist={artist.term}
                  />
                  <div class="music-fallback" id={`fallback-${artist.id}`}>
                    {artist.term.split(' ').map(w => w[0]).join('').slice(0, 2)}
                  </div>
                </div>
                <p class="music-name">{artist.term}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ── Section D: Podcasts ── -->
      <section class="section-padding section-divider">
        <div class="section-container">
          <p class="label mb-8">Podcasts</p>

          <div class="podcasts-grid">
            {podcasts.map((pod) => (
              <div class="podcast-item">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-3); flex-shrink: 0; margin-top: 2px;" aria-hidden="true">
                  <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/>
                  <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                  <line x1="12" x2="12" y1="19" y2="22"/>
                </svg>
                <span>{pod}</span>
              </div>
            ))}
          </div>
        </div>
      </section>

    </main>
    <Footer />
  </div>
</Layout>

<style>
  .about-bio {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 60ch;
  }
  .about-bio p {
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--text-2);
  }

  .about-more-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    transition: gap 0.15s;
  }
  .about-more-link:hover { gap: 0.6rem; }

  .headshot-img:hover { filter: grayscale(0%) !important; }

  /* ── Books ── */
  .books-grid {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .book-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 120px;
  }
  .book-cover-wrap {
    position: relative;
    width: 120px;
    height: 180px;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border);
    background-color: var(--bg-3);
  }
  .book-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .book-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'DM Mono', monospace;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-3);
    background-color: var(--bg-3);
  }
  .book-title {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.4;
  }
  .book-author {
    font-size: 0.68rem;
    color: var(--text-3);
  }
  .book-badge {
    display: inline-block;
    font-size: 0.65rem;
    font-family: 'DM Mono', monospace;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    background-color: var(--accent-light);
    color: var(--accent);
  }

  /* ── Music ── */
  .music-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 768px) {
    .music-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 480px) {
    .music-grid { grid-template-columns: repeat(2, 1fr); }
  }
  .music-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .music-art-wrap {
    position: relative;
    aspect-ratio: 1;
    border-radius: 8px;
    overflow: hidden;
    background-color: var(--bg-3);
  }
  .music-art {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8px;
    transition: transform 0.2s, box-shadow 0.2s;
    display: block;
  }
  .music-art:hover {
    transform: scale(1.03);
    box-shadow: 0 8px 24px rgba(0,0,0,0.18);
  }
  .music-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'DM Mono', monospace;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-3);
    background-color: var(--bg-3);
  }
  .music-name {
    font-size: 0.72rem;
    color: var(--text-2);
    line-height: 1.3;
  }

  /* ── Podcasts ── */
  .podcasts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem 2rem;
  }
  @media (max-width: 600px) {
    .podcasts-grid { grid-template-columns: 1fr; }
  }
  .podcast-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: var(--text-2);
    line-height: 1.4;
  }

  @keyframes pulseDot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(0.85); }
  }
</style>

<script>
  // Fetch iTunes album art client-side
  const artists = document.querySelectorAll<HTMLImageElement>('[data-artist]');

  artists.forEach(async (img) => {
    const term = img.getAttribute('data-artist');
    const id = img.id;
    const fallbackId = 'fallback-' + id.replace('music-', '');
    const fallback = document.getElementById(fallbackId);

    if (!term) return;

    try {
      const res = await fetch(
        `https://itunes.apple.com/search?term=${encodeURIComponent(term)}&entity=album&limit=1`
      );
      const data = await res.json();
      const artwork = data?.results?.[0]?.artworkUrl100;

      if (artwork) {
        const hires = artwork.replace('100x100', '400x400');
        img.src = hires;
        img.onload = () => {
          if (fallback) fallback.style.display = 'none';
        };
        img.onerror = () => {
          img.style.display = 'none';
        };
      } else {
        img.style.display = 'none';
      }
    } catch {
      img.style.display = 'none';
    }
  });
</script>
